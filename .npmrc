# Without this, `npm install` fails on Next.js 16 + React 19 with an
# ERESOLVE error from better-auth@1.x, which still declares
# `peerOptional next@"^14.0.0 || ^15.0.0"` in its package.json — see
# https://github.com/better-auth/better-auth/issues/6439 (open as of this
# writing). This is a packaging metadata lag, not an actual runtime
# incompatibility: better-auth's Next.js integration is just standard
# Request/Response objects under the hood (see app/api/auth/[...all]/route.ts),
# nothing version-specific to Next 14/15 vs 16. Remove this once that issue
# is closed and you've confirmed `npm install` succeeds without it.
legacy-peer-deps=true
