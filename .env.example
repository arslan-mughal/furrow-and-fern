# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
# A free Postgres instance from Neon (neon.com) or Supabase (supabase.com)
# works well for local development. Copy the connection string they give you.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Better Auth ---
# Generate with: npx auth@latest secret
BETTER_AUTH_SECRET="replace-with-a-generated-secret"
BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth (optional — leave blank to disable the Google button) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Facebook OAuth (optional — leave blank to disable the Facebook button) ---
# Create an app at https://developers.facebook.com/apps
# Valid OAuth redirect URI: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# --- Bank Transfer ---
# Fill in your own bank account details. These display on the checkout
# payment page — they're never hardcoded in source.
BANK_ACCOUNT_TITLE="Your Name or Business Name"
BANK_ACCOUNT_NUMBER="1234567890"
BANK_NAME="HBL / Meezan / etc."
# IBAN is optional — leave blank if you don't use it.
BANK_IBAN=""

# --- JazzCash ---
JAZZCASH_ACCOUNT_TITLE="Your Name"
JAZZCASH_NUMBER="03001234567"

# --- EasyPaisa ---
EASYPAISA_ACCOUNT_TITLE="Your Name"
EASYPAISA_NUMBER="03001234567"

# --- Resend (email) ---
# Get an API key at https://resend.com/api-keys — free tier is plenty for dev.
RESEND_API_KEY="re_..."
# Works immediately with no setup for testing (can only send to your own
# Resend account email until you verify a domain). Once you verify a domain
# in the Resend dashboard, change this to an address at that domain.
EMAIL_FROM="Furrow & Fern <onboarding@resend.dev>"

# --- Anthropic (AI assistant) ---
# Get an API key at https://console.anthropic.com/settings/keys
# The assistant widget runs without this set — it just shows an error
# message in the chat instead of a reply.
ANTHROPIC_API_KEY="sk-ant-..."

# --- Bank / Wallet payment details (shown at checkout) ---
# These appear on the payment instructions page — fill in your real details.
# The store runs without these set; checkout will just show placeholder text.
BANK_ACCOUNT_TITLE="Your Name"
BANK_ACCOUNT_NUMBER="0000-0000-0000-0000"
BANK_NAME="HBL / MCB / Meezan / etc."
BANK_IBAN="PK00XXXX0000000000000000"

JAZZCASH_ACCOUNT_TITLE="Your Name"
JAZZCASH_NUMBER="03XX-XXXXXXX"

EASYPAISA_ACCOUNT_TITLE="Your Name"
EASYPAISA_NUMBER="03XX-XXXXXXX"
